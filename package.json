{
  "name": "doudou-airline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Engineered local workspace for the Skyline Airlines browser game.",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build && node scripts/build-standalone.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "balance": "node scripts/simulate-balance.mjs",
    "balance:acceptance": "node scripts/accept-balance.mjs",
    "check": "npm run test && npm run build"
  },
  "devDependencies": {
    "vite": "^7.0.0",
    "vitest": "^3.2.0"
  }
}
